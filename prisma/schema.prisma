generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  phone         String    @unique
  name          String
  password      String?
  role          String    @default("buyer")
  avatar        String?
  aadhaarVerified Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  properties    Property[]
  siteVisits    SiteVisit[]
  reviews       Review[]
  conversations ConversationParticipant[]
  messages      Message[]
  leads        Lead[]
  payments     Payment[]
  notifications Notification[]
  agentProfile  Agent?
}

model Agent {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  agencyName      String?
  experience      Int       @default(0)
  specialization  String    @default("[]")
  areas           String    @default("[]")
  totalListings   Int       @default(0)
  totalDeals      Int       @default(0)
  rating          Float     @default(0)
  responseTime    Int       @default(0)
  verified        Boolean   @default(false)
  subscriptionTier String   @default("free")
  subscriptionExpiresAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  leads          Lead[]
  siteVisits     SiteVisit[]
}

model Property {
  id              String    @id @default(uuid())
  title           String
  description     String
  type            String
  status          String    @default("active")
  
  price           Float
  pricePerUnit    Float?
  expectedRent    Float?
  
  bedrooms        Int?
  bathrooms       Int?
  kitchens        Int?
  balconies       Int?
  carpetArea      Float?
  superArea       Float?
  plotArea        Float?
  length          Float?
  breadth         Float?
  
  city            String
  locality        String
  landmark        String?
  pincode         String
  latitude        Float
  longitude       Float
  localityRating  Float?
  
  floor           Int?
  totalFloors     Int?
  propertyAge     Int?
  facing          String?
  possessionDate  DateTime?
  
  landType        String?
  roadAccess      String?
  irrigationAvailable Boolean @default(false)
  boundaryWall    Boolean   @default(false)
  
  ownership       String    @default("freehold")
  
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id])
  agentId         String?
  agent           Agent?    @relation(fields: [agentId], references: [id])
  
  amenities       String    @default("[]")
  isFeatured      Boolean   @default(false)
  views           Int       @default(0)
  saves           Int       @default(0)
  
  nearSchool      Boolean   @default(false)
  nearHospital    Boolean   @default(false)
  nearRailwayStation Boolean @default(false)
  nearIndustrialArea Boolean @default(false)
  distanceToSchool Float?
  distanceToHospital Float?
  distanceToRailway Float?
  
  verificationStatus String @default("unverified")
  verificationDocuments String @default("[]")
  
  media           String    @default("[]")
  documents       String    @default("[]")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  siteVisits      SiteVisit[]
  leads           Lead[]
  reviews         Review[]
}

model SiteVisit {
  id            String    @id @default(uuid())
  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  agentId       String?
  agent         Agent?    @relation(fields: [agentId], references: [id])
  scheduledDate DateTime
  scheduledTime String
  status        String    @default("scheduled")
  notes         String?
  feedback      String?
  rating        Int?
  createdAt     DateTime  @default(now())
}

model Conversation {
  id            String    @id @default(uuid())
  propertyId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  participants  ConversationParticipant[]
  messages      Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  unreadCount    Int          @default(0)
  
  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  type           String       @default("text")
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Review {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  propertyId      String?
  property        Property? @relation(fields: [propertyId], references: [id])
  locality        String?
  city            String?
  rating          Float
  comment         String
  waterRating     Float?
  electricityRating Float?
  safetyRating    Float?
  helpfulCount    Int       @default(0)
  createdAt       DateTime  @default(now())
}

model Lead {
  id            String    @id @default(uuid())
  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  agentId       String
  agent         Agent     @relation(fields: [agentId], references: [id])
  status        String    @default("new")
  source        String    @default("search")
  notes         String?
  followUpDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Payment {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  type          String
  amount        Float
  currency      String    @default("INR")
  status        String    @default("pending")
  transactionId String?
  orderId       String    @unique
  createdAt     DateTime  @default(now())
}

model Notification {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  type          String
  title         String
  body          String
  data          String?
  read          Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

model AreaInsight {
  id            String    @id @default(uuid())
  locality      String
  city          String
  propertyType  String
  avgPrice      Float
  pricePerSqFt  Float
  trend         String    @default("stable")
  totalListings Int       @default(0)
  updatedAt     DateTime  @default(now())
}